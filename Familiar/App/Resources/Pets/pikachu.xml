      <end>
        <x>0</x>
        <y>0</y>
        <offsety>0</offsety>
        <opacity>1</opacity>
        <interval>200</interval>
      </end>
      <sequence repeatfrom="0" repeat="0">
        <frame>2</frame>
        <frame>3</frame>
        <next probability="10" only="none">1</next>
        <action>none</action>
      </sequence>
    </animation>
    <animation id="7">
      <name>fall</name>
      <start>
        <x>0</x>
        <y>8</y>
        <offsety>0</offsety>
        <opacity>1</opacity>
        <interval>100</interval>
      </start>
      <end>
        <x>0</x>
        <y>8</y>
