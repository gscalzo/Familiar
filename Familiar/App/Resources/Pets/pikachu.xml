<?xml version="1.0" encoding="utf-8"?>
<animations xmlns:xsd="https://esheep.petrucci.ch/ https://raw.githubusercontent.com/Adrianotiger/desktopPet/master/Resources/animations.xsd" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xmlns="https://esheep.petrucci.ch/">
  <header>
    <author>michelle!</author>
    <title>Pikachu</title>
    <petname>Pikachu</petname>
    <version>0.1</version>
    <info>Pikachu that wanders around your screen. Resources found on https://eeveeexpo.com/resources</info>
    <application>1</application>
    <icon><![CDATA[]]></icon>
  </header>
  <image>
    <tilesx>4</tilesx>
    <tilesy>4</tilesy>
    <png><![CDATA[]]></png>
    <transparency>Cyan</transparency>
  </image>
  <spawns>
    <spawn id="1" probability="20">
      <x>screenW-imageW</x>
      <y>areaH-imageH</y>
      <next probability="0">1</next>
    </spawn>
  </spawns>
  <animations>
    <animation id="1">
      <name>idle</name>
      <start>
        <x>0</x>
        <y>0</y>
        <offsety>0</offsety>
        <opacity>1</opacity>
        <interval>200</interval>
      </start>
      <end>
        <x>0</x>
        <y>0</y>
        <offsety>0</offsety>
        <opacity>1</opacity>
        <interval>200</interval>
      </end>
      <sequence repeatfrom="0" repeat="random/20+2">
        <frame>0</frame>
        <next probability="10" only="none">1</next>
        <next probability="10" only="none">2</next>
        <next probability="10" only="none">3</next>
        <next probability="10" only="none">4</next>
        <next probability="10" only="none">5</next>
        <next probability="10" only="none">8</next>
        <next probability="10" only="none">9</next>
        <next probability="10" only="none">10</next>
        <next probability="10" only="none">11</next>
        <action>none</action>
      </sequence>
    </animation>
    <animation id="2">
      <name>walk down</name>
      <start>
        <x>0</x>
        <y>6</y>
        <offsety>0</offsety>
        <opacity>1</opacity>
        <interval>200</interval>
      </start>
      <end>
        <x>random/20-5</x>
        <y>6</y>
        <offsety>0</offsety>
        <opacity>1</opacity>
        <interval>200</interval>
      </end>
      <sequence repeatfrom="0" repeat="5+random/10">
        <frame>0</frame>
        <frame>1</frame>
        <frame>2</frame>
        <frame>3</frame>
        <next probability="50" only="none">2</next>
        <next probability="50" only="none">1</next>
        <next probability="10" only="none">10</next>
        <next probability="10" only="none">11</next>
        <action>flip</action>
      </sequence>
      <border>
        <next probability="10" only="none">1</next>
      </border>
    </animation>
    <animation id="3">
      <name>Walk Up</name>
      <start>
        <x>0</x>
        <y>-6</y>
        <offsety>0</offsety>
        <opacity>1</opacity>
        <interval>200</interval>
      </start>
      <end>
        <x>random/20-5</x>
        <y>-6</y>
        <offsety>0</offsety>
        <opacity>1</opacity>
        <interval>200</interval>
      </end>
      <sequence repeatfrom="0" repeat="5+random/10">
        <frame>12</frame>
        <frame>13</frame>
        <frame>14</frame>
        <frame>15</frame>
        <next probability="50" only="none">3</next>
        <next probability="50" only="none">1</next>
        <next probability="10" only="none">8</next>
        <next probability="10" only="none">9</next>
        <action>none</action>
      </sequence>
      <border>
        <next probability="10" only="none">1</next>
      </border>
    </animation>
    <animation id="4">
      <name>Walk Left</name>
